# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2024-11-20.acacia

# PostgreSQL — uses asyncpg driver prefix
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stripe_integration

# Redis
REDIS_URL=redis://localhost:6379/0

# App
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace_with_a_strong_random_key

# Comma-separated list of allowed CORS origins (leave empty for backend-to-backend)
ALLOWED_ORIGINS=

DEBUG=false
